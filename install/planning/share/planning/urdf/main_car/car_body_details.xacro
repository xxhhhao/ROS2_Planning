<!-- 老式桑塔纳车身细节 -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- 使用父文件的参数 -->
    <xacro:property name="PI" value="3.141592653"/>

    <!-- 老式桑塔纳特征尺寸 -->
    <xacro:property name="hood_length" value="0.8"/>
    <xacro:property name="hood_width" value="${car_width - 0.1}"/>
    <xacro:property name="hood_height" value="0.05"/>

    <xacro:property name="trunk_length" value="0.7"/>
    <xacro:property name="trunk_width" value="${car_width - 0.1}"/>
    <xacro:property name="trunk_height" value="0.4"/>

    <xacro:property name="roof_length" value="1.2"/>
    <xacro:property name="roof_width" value="${car_width - 0.05}"/>
    <xacro:property name="roof_height" value="0.08"/>

    <xacro:property name="front_bumper_height" value="0.18"/>
    <xacro:property name="front_bumper_width" value="${car_width + 0.05}"/>

    <xacro:property name="rear_bumper_height" value="0.15"/>
    <xacro:property name="rear_bumper_width" value="${car_width + 0.05}"/>

    <!-- 挡风玻璃（垂直或小角度） -->
    <xacro:property name="windshield_height" value="0.4"/>
    <xacro:property name="windshield_length" value="0.08"/>
    <xacro:property name="windshield_angle" value="0.25"/>

    <!-- 后窗 -->
    <xacro:property name="rear_window_height" value="0.35"/>
    <xacro:property name="rear_window_length" value="0.08"/>
    <xacro:property name="rear_window_angle" value="0.35"/>

    <!-- 老式方形车灯 -->
    <xacro:property name="headlight_size" value="0.18"/>
    <xacro:property name="taillight_size" value="0.15"/>

    <!-- 雷达支架 -->
    <xacro:property name="radar_stand_height" value="0.15"/>
    <xacro:property name="radar_stand_width" value="0.08"/>

    <!-- 颜色定义（老式桑塔纳风格） - 简化版本 -->
    <material name="santana_white">
        <color rgba="0.85 0.85 0.85 0.98"/>
    </material>

    <material name="santana_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>

    <material name="chrome">
        <color rgba="0.7 0.7 0.7 1.0"/>
    </material>

    <material name="glass_dark">
        <color rgba="0.2 0.25 0.35 0.75"/>
    </material>

    <material name="headlight_yellow">
        <color rgba="1.0 0.95 0.7 1.0"/>
    </material>

    <material name="taillight_red">
        <color rgba="0.9 0.1 0.1 1.0"/>
    </material>

    <material name="santana_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>

    <material name="chrome">
        <color rgba="0.7 0.7 0.7 1.0"/>
    </material>

    <material name="glass_dark">
        <color rgba="0.2 0.25 0.35 0.75"/>
    </material>

    <material name="headlight_yellow">
        <color rgba="1.0 0.95 0.7 1.0"/>
    </material>

    <material name="taillight_red">
        <color rgba="0.9 0.1 0.1 1.0"/>
    </material>

    <!-- 引擎盖（平顶） -->
    <link name="hood">
        <visual>
            <origin xyz="${car_length/2.0 - hood_length/2.0 - 0.15} 0.0 ${car_height - hood_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${hood_length} ${hood_width} ${hood_height}"/>
            </geometry>
            <material name="santana_white"/>
        </visual>
    </link>

    <!-- 后备箱（高耸） -->
    <link name="trunk">
        <visual>
            <origin xyz="${-car_length/2.0 + trunk_length/2.0 + 0.1} 0.0 ${car_height - trunk_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${trunk_length} ${trunk_width} ${trunk_height}"/>
            </geometry>
            <material name="santana_white"/>
        </visual>
    </link>

    <!-- 车顶（平顶，老式特征） -->
    <link name="roof">
        <visual>
            <origin xyz="${-0.25} 0.0 ${car_height - 0.05 + roof_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${roof_length} ${roof_width} ${roof_height}"/>
            </geometry>
            <material name="santana_white"/>
        </visual>
    </link>

    <!-- 前挡风玻璃（小角度倾斜） -->
    <link name="windshield">
        <visual>
            <origin xyz="${car_length/2.0 - hood_length - 0.05 - windshield_length/2.0} 0.0 ${car_height - windshield_height/2.0}" rpy="${PI/180.0 * 20} 0.0 0.0"/>
            <geometry>
                <box size="${windshield_length} ${car_width} ${windshield_height}"/>
            </geometry>
            <material name="glass_dark"/>
        </visual>
    </link>

    <!-- 后窗（倾斜） -->
    <link name="rear_window">
        <visual>
            <origin xyz="${-car_length/2.0 + trunk_length + 0.05 + rear_window_length/2.0} 0.0 ${car_height - rear_window_height/2.0}" rpy="${PI/180.0 * -35} 0.0 0.0"/>
            <geometry>
                <box size="${rear_window_length} ${car_width} ${rear_window_height}"/>
            </geometry>
            <material name="glass_dark"/>
        </visual>
    </link>

    <!-- 前保险杠（宽大） -->
    <link name="front_bumper">
        <visual>
            <origin xyz="${car_length/2.0 + 0.08} 0.0 ${car_height/2.0 - front_bumper_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.16 ${front_bumper_width} ${front_bumper_height}"/>
            </geometry>
            <material name="santana_black"/>
        </visual>
    </link>

    <!-- 后保险杠 -->
    <link name="rear_bumper">
        <visual>
            <origin xyz="${-car_length/2.0 - 0.06} 0.0 ${car_height/2.0 - rear_bumper_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.12 ${rear_bumper_width} ${rear_bumper_height}"/>
            </geometry>
            <material name="santana_black"/>
        </visual>
    </link>

    <!-- 左前大灯（方形，老式特征） -->
    <link name="headlight_left">
        <visual>
            <origin xyz="${car_length/2.0} ${car_width/2.0 - 0.25} ${car_height/2.0 - 0.18}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.1 0.2 ${headlight_size}"/>
            </geometry>
            <material name="headlight_yellow"/>
        </visual>
    </link>

    <!-- 右前大灯 -->
    <link name="headlight_right">
        <visual>
            <origin xyz="${car_length/2.0} ${-car_width/2.0 + 0.25} ${car_height/2.0 - 0.18}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.1 0.2 ${headlight_size}"/>
            </geometry>
            <material name="headlight_yellow"/>
        </visual>
    </link>

    <!-- 左尾灯（方形） -->
    <link name="taillight_left">
        <visual>
            <origin xyz="${-car_length/2.0} ${car_width/2.0 - 0.25} ${car_height/2.0 - 0.12}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.08 0.2 ${taillight_size}"/>
            </geometry>
            <material name="taillight_red"/>
        </visual>
    </link>

    <!-- 右尾灯 -->
    <link name="taillight_right">
        <visual>
            <origin xyz="${-car_length/2.0} ${-car_width/2.0 + 0.25} ${car_height/2.0 - 0.12}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.08 0.2 ${taillight_size}"/>
            </geometry>
            <material name="taillight_red"/>
        </visual>
    </link>

    <!-- 车身腰线（老式特征） -->
    <link name="waist_line">
        <visual>
            <origin xyz="${-0.4} ${car_width/2.0} ${car_height/2.0 + 0.05}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${car_length - 0.8} 0.02 0.08"/>
            </geometry>
            <material name="chrome"/>
        </visual>
    </link>

    <!-- 雷达支架（放在车顶中央） -->
    <link name="radar_stand">
        <visual>
            <origin xyz="${-0.3} 0.0 ${car_height + radar_stand_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${radar_stand_width} ${radar_stand_width} ${radar_stand_height}"/>
            </geometry>
            <material name="santana_black"/>
        </visual>
    </link>

    <!-- 关联所有细节到base_link -->
    <joint name="hood_joint" type="fixed">
        <parent link="base_link"/>
        <child link="hood"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="trunk_joint" type="fixed">
        <parent link="base_link"/>
        <child link="trunk"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="roof_joint" type="fixed">
        <parent link="base_link"/>
        <child link="roof"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="windshield_joint" type="fixed">
        <parent link="base_link"/>
        <child link="windshield"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="rear_window_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_window"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="front_bumper_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_bumper"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="rear_bumper_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_bumper"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="headlight_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="headlight_left"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="headlight_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="headlight_right"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="taillight_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="taillight_left"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="taillight_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="taillight_right"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="waist_line_joint" type="fixed">
        <parent link="base_link"/>
        <child link="waist_line"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <joint name="radar_stand_joint" type="fixed">
        <parent link="base_link"/>
        <child link="radar_stand"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

</robot>
